---
import { getEntry, render } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const diaryEntry = await getEntry('home', 'diary');
const { Content } = diaryEntry ? await render(diaryEntry) : { Content: null };

const diaryPath = path.resolve('src/content/home/diary.md');
const lastUpdated = fs.existsSync(diaryPath) ? fs.statSync(diaryPath).mtime : new Date();
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-background text-foreground transition-colors duration-300 flex flex-col min-h-dvh">
		<Header />
		<main class="flex-grow flex flex-col justify-center px-4 py-12">
			<div class="prose prose-slate dark:prose-invert lg:prose-xl mx-auto w-full">
				<section class="space-y-6 text-center sm:text-left">
					<h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-8">
						Senior Frontend Engineer & Testing Automation Specialist
					</h1>
					<p class="text-lg text-muted-foreground leading-relaxed">
						我是 Yusong。大多數時間都在處理前端架構和自動化測試。我喜歡把複雜的工作流程變簡單，並確保程式碼跑起來既穩又快。這裡是我記錄技術心得和生活隨筆的地方。
					</p>
				</section>

				{Content && (
					<section class="mt-12 p-6 bg-muted/30 rounded-2xl border border-muted flex flex-col">
						<div class="text-sm font-bold mb-4 uppercase tracking-wider text-muted-foreground">Diary</div>
						<div class="italic text-muted-foreground flex-grow">
							<Content />
						</div>
						<div class="text-right mt-4">
							<span class="text-xs text-muted-foreground/60">
								<FormattedDate date={lastUpdated} />
							</span>
						</div>
					</section>
				)}

			</div>
		</main>
		<Footer />
	</body>
</html>
