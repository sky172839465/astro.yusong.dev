---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const posts = await getCollection('blog');
const seriesMap = new Map();

posts.forEach((post) => {
	const segments = post.id.split('/');
	if (segments.length > 1) {
		const seriesId = segments[0];
		if (!seriesMap.has(seriesId)) {
			seriesMap.set(seriesId, {
				id: seriesId,
				count: 0,
				lastUpdate: post.data.pubDate,
			});
		}
		const series = seriesMap.get(seriesId);
		series.count++;
		if (post.data.pubDate > series.lastUpdate) {
			series.lastUpdate = post.data.pubDate;
		}
	}
});

const seriesList = Array.from(seriesMap.values()).sort((a, b) => b.lastUpdate.valueOf() - a.lastUpdate.valueOf());
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={`系列文章 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-background text-foreground transition-colors duration-300 flex flex-col min-h-dvh">
		<Header />
		<main class="w-full max-w-4xl mx-auto px-4 py-12 flex-grow">
			<section>
				<h1 class="text-4xl font-bold mb-8 text-center">系列文章</h1>
				<div class="grid gap-6 md:grid-cols-2">
					{seriesList.map((series) => (
						<a
							href={`/blog/${series.id}/`}
							class="group relative overflow-hidden rounded-2xl border border-muted bg-muted/20 p-6 transition-all duration-300 hover:bg-muted/30 hover:shadow-lg"
						>
							<div class="flex flex-col h-full">
								<div class="mb-4 flex items-center justify-between">
									<span class="inline-flex items-center rounded-full bg-primary/10 px-2.5 py-0.5 text-xs font-semibold text-primary">
										Series
									</span>
									<span class="text-xs text-muted-foreground">
										{series.count} 篇文章
									</span>
								</div>
								<h2 class="text-2xl font-bold tracking-tight text-foreground group-hover:text-primary transition-colors duration-200">
									{series.id.split('-').join(' ').toUpperCase()}
								</h2>
								<div class="mt-auto pt-4 flex items-center text-sm text-muted-foreground">
									<span>查看完整系列</span>
									<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-1 transition-transform duration-200 group-hover:translate-x-1"><path d="m9 18 6-6-6-6"/></svg>
								</div>
							</div>
						</a>
					))}
				</div>
				{seriesList.length === 0 && (
					<p class="text-center text-muted-foreground mt-12">目前還沒有任何系列文章。</p>
				)}
			</section>
		</main>
		<Footer />
	</body>
</html>
