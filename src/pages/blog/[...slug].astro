---
import { type CollectionEntry, getCollection } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import SeriesIndex from '../../layouts/SeriesIndex.astro';
import { render } from 'astro:content';

export async function getStaticPaths() {
	const posts = await getCollection('blog');

	// Paths for individual posts
	const postPaths = posts.map((post) => ({
		params: { slug: post.id },
		props: { type: 'post', data: post },
	}));

	// Paths for series index pages
	const seriesIds = [...new Set(posts.map(p => p.id.split('/')).filter(s => s.length > 1).map(s => s[0]))];
	const seriesPaths = seriesIds.map(id => ({
		params: { slug: id },
		props: { type: 'series', id },
	}));

	return [...postPaths, ...seriesPaths];
}

const { type } = Astro.props;

let post: CollectionEntry<'blog'> | undefined;
let Content: any;
let headings: any;
let series: any;

let seriesPosts: CollectionEntry<'blog'>[] = [];
let seriesName = '';
let description = '';

if (type === 'post') {
	post = Astro.props.data as CollectionEntry<'blog'>;
	const rendered = await render(post);
	Content = rendered.Content;
	headings = rendered.headings;

	const pathSegments = post.id.split('/');
	const seriesId = pathSegments.length > 1 ? pathSegments[0] : null;
	const sName = seriesId ? seriesId.split('-').join(' ') : null;

	if (seriesId) {
		const allPosts = await getCollection('blog');
		seriesPosts = allPosts
			.filter((p) => p.id.startsWith(`${seriesId}/`))
			.sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());
		series = { id: seriesId, posts: seriesPosts, currentId: post.id };
	}
} else {
	const seriesId = Astro.props.id as string;
	const allPosts = await getCollection('blog');
	seriesPosts = allPosts
		.filter((p) => p.id.startsWith(`${seriesId}/`))
		.sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());
	seriesName = seriesId.split('-').join(' ').toUpperCase();
	description = `這是關於 ${seriesName} 的系列文章，共 ${seriesPosts.length} 篇。`;
}
---

{type === 'post' ? (
	<BlogPost {...post!.data} headings={headings} series={series}>
		<Content />
	</BlogPost>
) : (
	<SeriesIndex seriesName={seriesName} description={description} posts={seriesPosts} />
)}
