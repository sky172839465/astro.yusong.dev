---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const posts = await getCollection('blog');
const tags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Tags | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-background text-foreground transition-colors duration-300">
		<Header />
		<main class="w-full max-w-4xl mx-auto px-4 py-12">
			<section>
				<h1 class="text-4xl font-bold mb-8 text-center">Tags</h1>
				<div class="flex flex-wrap gap-4 justify-center">
					{tags.map((tag) => (
						<a
							href={`/tags/${tag.toLowerCase()}/`}
							class="px-4 py-2 bg-muted hover:bg-muted/80 rounded-full transition-colors duration-200"
						>
							{tag}
						</a>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
