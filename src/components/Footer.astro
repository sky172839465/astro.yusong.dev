---
import { Github } from 'lucide-react';
const today = new Date();
---

<footer class="px-4 py-8 pb-24 sm:pb-4 text-muted-foreground bg-muted/30">
	<div class="max-w-7xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-4">
		<div class="text-sm">
			&copy; {today.getFullYear()} YuSong Hsu. All rights reserved.
		</div>
		<div class="flex items-center gap-4">
			<a href="https://github.com/sky172839465" target="_blank" class="no-underline text-muted-foreground hover:text-foreground transition-colors">
				<span class="sr-only">Go to YuSong's GitHub repo</span>
				<Github size={24} />
			</a>
		</div>
	</div>
</footer>
